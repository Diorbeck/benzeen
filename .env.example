# Database (Docker)
DATABASE_URL="postgresql://fuelflow:fuelflow_secret@localhost:5433/fuelflow?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Bootstrap SUPER_ADMIN (optional)
# If set, the app will ensure this SUPER_ADMIN exists (and update password on start).
SUPER_ADMIN_EMAIL="admin@benzeen.uz"
SUPER_ADMIN_PASSWORD="AD4543895"

# One-time data wipe: set to "true" to delete ALL records on next deploy and
# recreate only the SUPER_ADMIN (+ prices). Remove it again right after.
# RESET_DEMO_DATA="true"

# Verification codes — see docs/VERIFICATION.md
# Email (Resend): https://resend.com — verify domain at resend.com/domains to send to any email
RESEND_API_KEY="re_xxxx"
# RESEND_FROM_EMAIL="noreply@yourdomain.com"

# SMS (Twilio): npm install twilio, then set below to send codes by phone
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER="+998901234567"

# --- Rate limiting (Upstash Redis) ------------------------------------------
# Auth brute-force protection. If unset, rate limiting is DISABLED (allow all).
# Create a database at https://console.upstash.com (Redis) and copy REST creds.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- Error monitoring (Sentry) ----------------------------------------------
# If DSN is unset, Sentry is inert (no-op). Create a project at sentry.io.
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""          # same DSN, exposed to the browser
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""               # prod CI only — enables source-map upload
# SENTRY_TRACES_SAMPLE_RATE="0.1"            # optional (server/edge)
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1" # optional (browser)

# --- Web Push (PWA notifications) -------------------------------------------
# Generate VAPID keys: npx web-push generate-vapid-keys
# If unset, push is DISABLED (no-op). Public key must be exposed to the client.
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""    # same as VAPID_PUBLIC_KEY
# VAPID_SUBJECT="mailto:admin@benzeen.uz"

# --- App URL (used for metadataBase / absolute links) -----------------------
# NEXT_PUBLIC_APP_URL="https://benzeen.uz"

# --- Telegram bot + Mini App (driver orders) --------------------------------
# Create a bot via @BotFather, then paste its token below. If unset, all
# Telegram features are DISABLED (no-op) and /tg shows "open in Telegram".
# TELEGRAM_BOT_TOKEN=""
# Secret you choose when registering the webhook (setWebhook?secret_token=...).
# Telegram echoes it back in X-Telegram-Bot-Api-Secret-Token; we verify it.
# TELEGRAM_WEBHOOK_SECRET=""
# Mini App URL opened from the bot. Defaults to NEXT_PUBLIC_APP_URL + /tg.
# NEXT_PUBLIC_TG_MINIAPP_URL="https://benzeen.uz/tg"
# Operator phone shown to drivers when they dispute a courier-reported amount.
# OPERATOR_PHONE="+998901234567"
